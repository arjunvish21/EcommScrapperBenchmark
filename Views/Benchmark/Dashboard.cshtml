@model EcommScrapperBenchmark.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var hasData = Model.ProviderSummaries.Any();
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1>📊 Benchmark Dashboard</h1>
        <p class="subtitle">Compare scraping API providers across success rate, response time, and data quality</p>
    </div>
    <div class="d-flex gap-1">
        @if (Model.RecentRuns.Any())
        {
            <form asp-controller="Benchmark" asp-action="Dashboard" method="get" class="d-flex gap-1">
                <select name="runId" class="form-control" style="min-width: 200px;" onchange="this.form.submit()">
                    <option value="">All Runs (Aggregate)</option>
                    @foreach (var run in Model.RecentRuns)
                    {
                        var isSelected = ViewBag.SelectedRunId != null && (int)ViewBag.SelectedRunId == run.Id;
                        if (isSelected)
                        {
                            <option value="@run.Id" selected>
                                Run #@run.Id — @run.StartedAt.ToString("MMM dd, HH:mm") (@run.Status)
                            </option>
                        }
                        else
                        {
                            <option value="@run.Id">
                                Run #@run.Id — @run.StartedAt.ToString("MMM dd, HH:mm") (@run.Status)
                            </option>
                        }
                    }
                </select>
            </form>
        }
        <form asp-controller="Benchmark" asp-action="Start" method="post">
            <button type="submit" class="btn btn-primary btn-lg" disabled="@ViewBag.IsRunning">
                @if ((bool)ViewBag.IsRunning)
                {
                    <span class="spinner"></span>
                    <span>Running...</span>
                }
                else
                {
                    <span>🚀 Run Benchmark</span>
                }
            </button>
        </form>
    </div>
</div>

@if (!hasData)
{
    <div class="empty-state">
        <div class="empty-icon">📊</div>
        <h3>No Benchmark Data Yet</h3>
        <p>Configure your API providers, add test products, and run your first benchmark to see results here.</p>
        <div class="d-flex gap-1 justify-center" style="justify-content: center;">
            <a href="@Url.Action("Index", "Providers")" class="btn btn-outline">🔌 Configure Providers</a>
            <a href="@Url.Action("Index", "Products")" class="btn btn-outline">📦 View Products</a>
        </div>
    </div>
}
else
{
    <!-- Overall Stats Cards -->
    <div class="stats-grid animate-fade-in-up">
        <div class="stat-card accent-info">
            <div class="stat-label">Total Runs</div>
            <div class="stat-value text-primary-accent">@Model.Overall.TotalRuns</div>
            <div class="stat-detail">@Model.Overall.TotalProvidersTested providers tested</div>
        </div>
        <div class="stat-card accent-primary">
            <div class="stat-label">Total Requests</div>
            <div class="stat-value" style="color: var(--accent-primary-light);">@Model.Overall.TotalRequests.ToString("N0")</div>
            <div class="stat-detail">across all runs</div>
        </div>
        <div class="stat-card accent-success">
            <div class="stat-label">Overall Success Rate</div>
            <div class="stat-value text-success">@Model.Overall.OverallSuccessRate%</div>
            <div class="score-bar"><div class="score-fill @(Model.Overall.OverallSuccessRate >= 80 ? "score-high" : Model.Overall.OverallSuccessRate >= 50 ? "score-medium" : "score-low")" style="width: @Model.Overall.OverallSuccessRate%"></div></div>
        </div>
        <div class="stat-card accent-warning">
            <div class="stat-label">Avg Response Time</div>
            <div class="stat-value text-warning">@Model.Overall.OverallAvgResponseTime.ToString("N0")<span style="font-size: 0.8rem; font-weight: 400;">ms</span></div>
            <div class="stat-detail">across all providers</div>
        </div>
        <div class="stat-card accent-danger">
            <div class="stat-label">Avg Data Quality</div>
            <div class="stat-value" style="color: var(--accent-tertiary);">@Model.Overall.OverallAvgQuality.ToString("N1")<span style="font-size: 0.8rem; font-weight: 400;">/100</span></div>
            <div class="score-bar"><div class="score-fill @(Model.Overall.OverallAvgQuality >= 70 ? "score-high" : Model.Overall.OverallAvgQuality >= 40 ? "score-medium" : "score-low")" style="width: @Model.Overall.OverallAvgQuality%"></div></div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="dashboard-grid animate-fade-in-up delay-2">
        <div class="chart-container">
            <div class="chart-title">🎯 Success Rate by Provider</div>
            <div class="chart-wrapper">
                <canvas id="successRateChart"></canvas>
            </div>
        </div>
        <div class="chart-container">
            <div class="chart-title">⏱️ Avg Response Time by Provider (ms)</div>
            <div class="chart-wrapper">
                <canvas id="responseTimeChart"></canvas>
            </div>
        </div>
    </div>

    <div class="dashboard-grid animate-fade-in-up delay-3">
        <div class="chart-container">
            <div class="chart-title">💎 Data Quality Score by Provider</div>
            <div class="chart-wrapper">
                <canvas id="qualityChart"></canvas>
            </div>
        </div>
        <div class="chart-container">
            <div class="chart-title">📊 Quality Breakdown (Completeness / Accuracy / Structure)</div>
            <div class="chart-wrapper">
                <canvas id="qualityBreakdownChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Provider Comparison Table -->
    <div class="table-container animate-fade-in-up delay-4">
        <div class="table-header">
            <h3>🏆 Provider Comparison</h3>
            <span class="badge badge-info">@Model.ProviderSummaries.Count providers</span>
        </div>
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>Provider</th>
                        <th>Requests</th>
                        <th>Success Rate</th>
                        <th>Avg Response</th>
                        <th>Quality Score</th>
                        <th>Completeness</th>
                        <th>Accuracy</th>
                        <th>Structure</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var rank = 1; }
                    @foreach (var p in Model.ProviderSummaries)
                    {
                        <tr>
                            <td>
                                @if (rank == 1) { <span style="font-size: 1.2rem;">🥇</span> }
                                else if (rank == 2) { <span style="font-size: 1.2rem;">🥈</span> }
                                else if (rank == 3) { <span style="font-size: 1.2rem;">🥉</span> }
                                else { <span class="text-muted">#@rank</span> }
                            </td>
                            <td>
                                <span class="provider-name">
                                    <span class="provider-dot @p.ProviderName.ToLower()"></span>
                                    @p.ProviderName
                                </span>
                            </td>
                            <td>
                                <span class="font-semibold">@p.TotalRequests</span>
                                <span class="text-muted" style="font-size: 0.75rem;"> (@p.SuccessfulRequests ✓ / @p.FailedRequests ✗)</span>
                            </td>
                            <td>
                                <span class="badge @(p.SuccessRate >= 80 ? "badge-success" : p.SuccessRate >= 50 ? "badge-warning" : "badge-danger")">
                                    @p.SuccessRate%
                                </span>
                            </td>
                            <td>
                                <span class="font-semibold">@p.AvgResponseTimeMs.ToString("N0")</span>
                                <span class="text-muted">ms</span>
                            </td>
                            <td>
                                <div class="d-flex align-center gap-1">
                                    <span class="font-semibold @(p.AvgQualityScore >= 70 ? "text-success" : p.AvgQualityScore >= 40 ? "text-warning" : "text-danger")">
                                        @p.AvgQualityScore.ToString("N1")
                                    </span>
                                    <div class="score-bar" style="width: 60px;">
                                        <div class="score-fill @(p.AvgQualityScore >= 70 ? "score-high" : p.AvgQualityScore >= 40 ? "score-medium" : "score-low")"
                                             style="width: @p.AvgQualityScore%"></div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-secondary">@p.AvgCompletenessScore.ToString("N1")</td>
                            <td class="text-secondary">@p.AvgAccuracyScore.ToString("N1")</td>
                            <td class="text-secondary">@p.AvgStructureScore.ToString("N1")</td>
                        </tr>
                        rank++;
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Platform Heatmap -->
    @if (Model.PlatformBreakdowns.Any())
    {
        var platforms = Model.PlatformBreakdowns.Select(b => b.Platform).Distinct().ToList();
        var providers = Model.PlatformBreakdowns.Select(b => b.ProviderName).Distinct().ToList();

        <div class="table-container animate-fade-in-up delay-5 mt-3">
            <div class="table-header">
                <h3>🗺️ Success Rate Heatmap (Provider × Platform)</h3>
            </div>
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Provider</th>
                            @foreach (var platform in platforms)
                            {
                                <th class="text-center">@platform</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var provider in providers)
                        {
                            <tr>
                                <td>
                                    <span class="provider-name">
                                        <span class="provider-dot @provider.ToLower()"></span>
                                        @provider
                                    </span>
                                </td>
                                @foreach (var platform in platforms)
                                {
                                    var entry = Model.PlatformBreakdowns.FirstOrDefault(b => b.ProviderName == provider && b.Platform == platform);
                                    <td class="text-center">
                                        @if (entry != null)
                                        {
                                            <span class="badge @(entry.SuccessRate >= 80 ? "badge-success" : entry.SuccessRate >= 50 ? "badge-warning" : "badge-danger")"
                                                  data-tooltip="@entry.SuccessfulRequests/@entry.TotalRequests requests, @entry.AvgResponseTimeMs.ToString("N0")ms avg">
                                                @entry.SuccessRate%
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@section Scripts {
    @if (hasData)
    {
        <script>
            // Chart.js global defaults for dark theme
            Chart.defaults.color = '#8b92a5';
            Chart.defaults.borderColor = 'rgba(255, 255, 255, 0.06)';
            Chart.defaults.font.family = "'Inter', sans-serif";

            const providerNames = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ProviderSummaries.Select(p => p.ProviderName)));
            const successRates = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ProviderSummaries.Select(p => p.SuccessRate)));
            const responseTimes = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ProviderSummaries.Select(p => p.AvgResponseTimeMs)));
            const qualityScores = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ProviderSummaries.Select(p => p.AvgQualityScore)));
            const completenessScores = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ProviderSummaries.Select(p => p.AvgCompletenessScore)));
            const accuracyScores = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ProviderSummaries.Select(p => p.AvgAccuracyScore)));
            const structureScores = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ProviderSummaries.Select(p => p.AvgStructureScore)));

            const providerColors = [
                '#6c5ce7', '#00cec9', '#fd79a8', '#fdcb6e', '#00b894',
                '#e17055', '#74b9ff', '#a29bfe', '#fab1a0', '#81ecec',
                '#dfe6e9', '#ffeaa7'
            ];

            // Success Rate Chart
            new Chart(document.getElementById('successRateChart'), {
                type: 'bar',
                data: {
                    labels: providerNames,
                    datasets: [{
                        label: 'Success Rate (%)',
                        data: successRates,
                        backgroundColor: providerColors.map(c => c + '40'),
                        borderColor: providerColors,
                        borderWidth: 2,
                        borderRadius: 6,
                        borderSkipped: false
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, max: 100, grid: { color: 'rgba(255,255,255,0.04)' } },
                        x: { grid: { display: false } }
                    }
                }
            });

            // Response Time Chart
            new Chart(document.getElementById('responseTimeChart'), {
                type: 'bar',
                data: {
                    labels: providerNames,
                    datasets: [{
                        label: 'Avg Response Time (ms)',
                        data: responseTimes,
                        backgroundColor: providerColors.map(c => c + '40'),
                        borderColor: providerColors,
                        borderWidth: 2,
                        borderRadius: 6,
                        borderSkipped: false
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.04)' } },
                        x: { grid: { display: false } }
                    }
                }
            });

            // Quality Score Chart
            new Chart(document.getElementById('qualityChart'), {
                type: 'bar',
                data: {
                    labels: providerNames,
                    datasets: [{
                        label: 'Quality Score',
                        data: qualityScores,
                        backgroundColor: qualityScores.map(s => s >= 70 ? 'rgba(0,184,148,0.3)' : s >= 40 ? 'rgba(253,203,110,0.3)' : 'rgba(225,112,85,0.3)'),
                        borderColor: qualityScores.map(s => s >= 70 ? '#00b894' : s >= 40 ? '#fdcb6e' : '#e17055'),
                        borderWidth: 2,
                        borderRadius: 6,
                        borderSkipped: false
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, max: 100, grid: { color: 'rgba(255,255,255,0.04)' } },
                        x: { grid: { display: false } }
                    }
                }
            });

            // Quality Breakdown Chart (grouped bar)
            new Chart(document.getElementById('qualityBreakdownChart'), {
                type: 'bar',
                data: {
                    labels: providerNames,
                    datasets: [
                        {
                            label: 'Completeness',
                            data: completenessScores,
                            backgroundColor: 'rgba(108, 92, 231, 0.4)',
                            borderColor: '#6c5ce7',
                            borderWidth: 1,
                            borderRadius: 4
                        },
                        {
                            label: 'Accuracy',
                            data: accuracyScores,
                            backgroundColor: 'rgba(0, 206, 201, 0.4)',
                            borderColor: '#00cec9',
                            borderWidth: 1,
                            borderRadius: 4
                        },
                        {
                            label: 'Structure',
                            data: structureScores,
                            backgroundColor: 'rgba(253, 121, 168, 0.4)',
                            borderColor: '#fd79a8',
                            borderWidth: 1,
                            borderRadius: 4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top',
                            labels: { usePointStyle: true, pointStyle: 'circle', padding: 16, font: { size: 11 } }
                        }
                    },
                    scales: {
                        y: { beginAtZero: true, max: 100, grid: { color: 'rgba(255,255,255,0.04)' } },
                        x: { grid: { display: false } }
                    }
                }
            });

            // Auto-refresh if benchmark is running
            @if ((bool)ViewBag.IsRunning)
            {
                <text>
                setInterval(() => {
                    fetch('/Benchmark/Status')
                        .then(r => r.json())
                        .then(data => {
                            if (!data.isRunning) {
                                window.location.reload();
                            }
                        });
                }, 10000);
                </text>
            }
        </script>
    }
}
