@model EcommScrapperBenchmark.Models.TestProduct
@{
    ViewData["Title"] = "Add Product";
}

<div class="page-header">
    <div>
        <h1>➕ Add Test Product</h1>
        <p class="subtitle">Add a new product URL for benchmarking</p>
    </div>
    <a asp-action="Index" class="btn btn-outline">← Back</a>
</div>

<div class="card animate-fade-in-up" style="max-width: 700px;">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="form-group">
                <label class="form-label">Platform *</label>
                <select asp-for="Platform" class="form-control">
                    <option value="">Select platform...</option>
                    <option value="Amazon">Amazon</option>
                    <option value="HomeDepot">Home Depot</option>
                    <option value="Walmart">Walmart</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Product URL *</label>
                <input asp-for="ProductUrl" class="form-control" placeholder="https://www.amazon.com/dp/..." />
            </div>

            <div class="form-group">
                <label class="form-label">Product Name</label>
                <input asp-for="ProductName" class="form-control" placeholder="e.g. Apple AirPods Pro" />
            </div>

            <div class="form-group">
                <label class="form-label">UPC Code</label>
                <input asp-for="UpcCode" class="form-control" placeholder="e.g. 194253415367" />
            </div>

            <div class="form-group">
                <label class="form-label">Expected Price (for accuracy scoring)</label>
                <input asp-for="ExpectedPrice" type="number" step="0.01" class="form-control" placeholder="e.g. 249.99" />
            </div>

            <div class="form-group">
                <label class="form-label">Expected Brand (for accuracy scoring)</label>
                <input asp-for="ExpectedBrand" class="form-control" placeholder="e.g. Apple" />
            </div>

            <div class="form-group">
                <label class="form-check">
                    <input asp-for="IsActive" type="checkbox" class="form-check-input" checked />
                    <span>Active (include in benchmark runs)</span>
                </label>
            </div>

            <div class="d-flex gap-1 mt-3">
                <button type="submit" class="btn btn-success">✓ Save Product</button>
                <a asp-action="Index" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>
